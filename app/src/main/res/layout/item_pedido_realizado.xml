<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_margin="8dp"
    android:background="@drawable/list_item_background"
    android:elevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNumOrdHistorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pedido #123"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#004d40"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENTREGADO"
            android:textStyle="bold"
            android:textColor="#388E3C"/> </LinearLayout>

    <TextView
        android:id="@+id/tvClienteFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Juan Pérez - 04/04/2026 14:30"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        android:textColor="@color/black"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvDestinoHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Destino: Av. Reforma 123"
        android:textColor="#424242"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btnVerEstadisticas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Ver Estadísticas del Viaje"
        android:backgroundTint="#00796B"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:cornerRadius="8dp"/>

</LinearLayout>