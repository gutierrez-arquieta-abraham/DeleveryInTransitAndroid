<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_conexion">

    <fragment
        android:id="@+id/nav_conexion"
        android:name="com.PolicodeLabs.Delevery_In_Transit.ui.conexion.ConexionFragment"
        android:label="@string/title_conexion" tools:layout="@layout/fragment_conexion" />
    <action
        android:id="@+id/action_conexion_to_pedidos"
        app:destination="@id/nav_pedidos"
        app:popUpTo="@id/nav_conexion"
        app:popUpToInclusive="true" />

    <fragment
        android:id="@+id/nav_pedidos"
        android:name="com.PolicodeLabs.Delevery_In_Transit.ui.pedidos.PedidosFragment"
        android:label="@string/title_pedidos"   tools:layout="@layout/fragment_pedidos" />

    <fragment
        android:id="@+id/nav_estadisticas"
        android:name="com.PolicodeLabs.Delevery_In_Transit.ui.dashboard.DashboardFragment"
        android:label="Estadisitcas Generales"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/nav_servicio"
        android:name="com.PolicodeLabs.Delevery_In_Transit.ui.servicio.ServicioFragment"
        android:label="@string/title_servicio"  tools:layout="@layout/fragment_servicio" />

</navigation>